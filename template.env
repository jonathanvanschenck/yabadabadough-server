# Copy to `.env`. Real environment variables always win over this file, so a
# container's configuration is never fought by a stray .env baked into an image.
#
# Booleans must be exactly "true" to count as true -- a typo fails closed.

# Required. Absolute paths are used as given; relative ones resolve against the
# app root (NOT the working directory), so scripts/ and index.js always agree.
# ":memory:" gives an ephemeral database.
YDD_SQLITE_PATH="db/backup/db.sqlite"

# Directory of Ed25519 JWT key pairs (default: ./keys); bootstrap with scripts/generate-jwt-key.js
# YDD_JWT_KEYS_DIR="keys"

# Set false for local plain-http development (cookies lose the Secure flag)
# YDD_SECURE_COOKIES="true"

# Bypasses every auth gate. Development only.
# YDD_DISABLE_AUTH="false"

# Where to listen. Use 0.0.0.0 in a container.
# YDD_SERVER_ADDRESS="localhost"
# YDD_SERVER_PORT="1234"

# Cosmetic only: the public URL announced in the startup log.
# YDD_PROXY_ADDRESS="localhost"
# YDD_PROXY_PORT="443"
# YDD_PROXY_PROTOCOL="https"

# debug | info | warn | error
# YDD_LOG_LEVEL="debug"
# Set false to drop ANSI escapes (log files, log shippers, container logs).
# YDD_LOG_COLORIZED="true"
# full | short | simple -- how much prefix each line carries.
# YDD_LOG_VERBOSITY="full"
