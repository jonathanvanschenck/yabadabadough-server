# Copy to `.env` next to docker-compose.yml and fill in.
#
# Compose reads this file automatically for ${VAR} interpolation; the app's own
# configuration lives in the compose `environment:` blocks, not here.

# Public hostname. Must already resolve (A/AAAA record) to this host before you
# run ./init-letsencrypt.sh -- Let's Encrypt validates by fetching over http.
DOMAIN=money.example.com

# Where Let's Encrypt sends expiry warnings.
LETSENCRYPT_EMAIL=you@example.com
